          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/ssoApiAuthV1LogoutResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ssoApiAuthV1LogoutRequest"
            }
          }
        ],
        "tags": [
          "Auth API"
        ]
      }
    },

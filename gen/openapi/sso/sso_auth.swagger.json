{
  "swagger": "2.0",
  "info": {
    "title": "Frontend Auth API",
    "description": "API для фронтенда. Backend проксирует запросы в SSO и возвращает токены, профиль и permissions.",
    "version": "1.0"
  },
  "tags": [
    {
      "name": "AuthApiService"
    },
    {
      "name": "AuthService"
    }
  ],
  "schemes": [
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/api/auth/exchange": {
      "post": {
        "summary": "Обмен OAuth2 code на access/refresh токены",
        "description": "Backend вызывает SSO.AuthService.ExchangeCode",
        "operationId": "AuthApiService_ExchangeCode",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/ssoApiAuthV1ExchangeCodeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ssoApiAuthV1ExchangeCodeRequest"
            }
          }
        ],
        "tags": [
          "Auth API"
        ]
      }
    },
    "/v1/api/auth/logout": {
      "post": {
        "summary": "Выход пользователя",
        "description": "Backend вызывает SSO.AuthService.Logout",

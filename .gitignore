# Ignore generated npm artifacts under gen recursively
gen/**/node_modules/
gen/**/package.json
gen/**/package-lock.json
gen/**/pnpm-lock.yaml
gen/**/*.tgz
gen/**/.npmrc
gen/**/dist/
gen/**/build/
gen/**/.artifacts/
gen/**/pkg/
gen/**/pnpm-debug.log

# Ignore any package.template.json copies inside gen (but keep root package.template.json)
gen/**/package.template.json

# General ignores
node_modules/
.pnpm-store/
*.tgz
.npmrc
.env
.vscode/
.idea
.DS_Store
